ANTHROPIC_API_KEY=

# Scheduler (cron route protection). Genera un secreto largo y aleatorio.
CRON_SECRET=
# CRON_LIVE=true habilita el envio REAL de aplicaciones. Dejar vacio/false para dry-run.
CRON_LIVE=false

# Clerk (auth). Consigue estas keys en https://dashboard.clerk.com -> tu app -> API Keys.
# Si estan vacias, la app usa el login por cookie (fallback de desarrollo).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Rutas de Clerk (dejar asi salvo que cambies los paths).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
